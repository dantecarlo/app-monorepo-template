# Supabase — required only if you wire up a real data layer.
# The template ships with mock data so these are optional for local dev.
# Copy this file to .env.local and fill in your project credentials.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Observability — Sentry is the DEFAULT adapter (swap in
# src/lib/observability/observability.adapter.ts). All keys are OPTIONAL:
# with no DSN the Sentry adapter and sentry.*.config files no-op, so build
# and validate stay green credential-free.
# ---------------------------------------------------------------------------

# Public Sentry DSN for the web app. Absent = Sentry disabled (enabled:!!dsn).
NEXT_PUBLIC_SENTRY_DSN=

# Deploy-time ONLY. Gates source-map upload in next.config withSentryConfig
# (sourcemaps.disable:!token). Absent locally/CI = no upload, silent.
# NEVER expose as NEXT_PUBLIC_ -- this is a server/deploy secret.
SENTRY_AUTH_TOKEN=

# Optional Sentry environment tag (defaults to development).
NEXT_PUBLIC_APP_ENV=development

# ---------------------------------------------------------------------------
# Cloudflare / edge security
# See docs/infrastructure.md for full setup instructions.
# ---------------------------------------------------------------------------

# Shared secret that Cloudflare injects into every request (Transform Rule or
# Worker) as the x-cf-origin-secret header. The Next.js middleware verifies it
# via the origin-guard adapter and returns 403 when it is absent or wrong,
# preventing attackers from hitting the Vercel URL directly. Absent = the
# Cloudflare origin guard passes through (NOT_CONFIGURED) so local/preview is
# not 403d. Set in production to lock the Vercel origin.
CF_ORIGIN_SECRET=

# Cloudflare Turnstile -- invisible CAPTCHA for signup and abuse-prone forms.
# Get both keys from the Cloudflare dashboard -> Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-side Turnstile siteverify secret. Absent = the Turnstile bot-protection
# adapter no-ops verifyToken to { success: true } (permissive degrade) so the
# verify route works credential-free in dev. NEVER expose as NEXT_PUBLIC_.
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Image delivery (cost + hotlink/scrape protection)
# Public is the DEFAULT (no signing). Swap the adapter in
# src/lib/image-delivery/imageDelivery.adapter.ts to enable signed delivery.
# All keys are OPTIONAL: absent = adapters degrade to public URLs so build and
# validate stay green credential-free. See docs/images.md.
# ---------------------------------------------------------------------------

# Cloudflare Images -- signed delivery URLs for private images.
# CLOUDFLARE_IMAGES_ACCOUNT_HASH is the public delivery account hash (safe).
CLOUDFLARE_IMAGES_ACCOUNT_HASH=
# Server-side HMAC key that signs delivery URLs. NEVER expose as NEXT_PUBLIC_.
CLOUDFLARE_IMAGES_SIGNING_KEY=

# Cloudflare R2 -- public static assets + optional signed delivery.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
# R2 secret -- NEVER expose as NEXT_PUBLIC_.
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for R2 assets (used to build delivery URLs).
R2_PUBLIC_BASE_URL=
