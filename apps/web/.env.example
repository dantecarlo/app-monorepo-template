# Supabase — required only if you wire up a real data layer.
# The template ships with mock data so these are optional for local dev.
# Copy this file to .env.local and fill in your project credentials.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Cloudflare / edge security
# See docs/infrastructure.md for full setup instructions.
# ---------------------------------------------------------------------------

# Shared secret that Cloudflare injects into every request (Transform Rule or
# Worker). Next.js middleware must verify this header and reject requests that
# arrive without it, preventing attackers from hitting the Vercel URL directly.
CF_ORIGIN_SECRET=

# Cloudflare Turnstile — invisible CAPTCHA for signup and abuse-prone forms.
# Get both keys from the Cloudflare dashboard → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare R2 — public static assets (logos, icons, downloadable files).
# Only required if you use R2 for asset storage; leave blank otherwise.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
