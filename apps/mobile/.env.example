# Supabase — required only if you wire up a real data layer.
# The template ships with mock data so these are optional for local dev.
# Copy this file to .env and fill in your project credentials.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Observability — Sentry is the DEFAULT adapter (swap in
# src/lib/observability/observability.adapter.ts). Keys are OPTIONAL: with no
# DSN the @sentry/react-native init and the adapter no-op, so the app runs
# fine without it. Real capture requires a native dev build (not Expo Go).
# ---------------------------------------------------------------------------

# Public Sentry DSN for the mobile app. Absent = Sentry disabled.
EXPO_PUBLIC_SENTRY_DSN=

# Optional Sentry environment tag (defaults to 'development').
EXPO_PUBLIC_APP_ENV=development
