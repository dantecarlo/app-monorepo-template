{
  "name": "@app/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "export:ci": "expo export --platform ios --platform android --output-dir dist",
    "export:web": "expo export --platform web --output-dir dist-web",
    "serve:web": "expo export --platform web --output-dir dist-web && pnpm exec serve dist-web -p 3001 -s --no-clipboard",
    "smoke:export": "pnpm export:ci && node ../../scripts/assert-expo-export.mjs",
    "smoke:mobile-web": "pnpm export:web && E2E_MOBILE_WEB=1 pnpm exec playwright test --project=mobile-web-390 --project=mobile-web-768 --project=mobile-web-1280 --project=mobile-web-1920"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "dependencies": {
    "@app/core": "workspace:*",
    "@app/i18n": "workspace:*",
    "@app/supabase": "workspace:*",
    "@app/tokens": "workspace:*",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/montserrat": "^0.2.3",
    "@expo/metro-runtime": "~56.0.15",
    "@formatjs/intl-pluralrules": "^6.3.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^8.16.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.1",
    "expo": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "i18next": "^26.3.2",
    "i18next-icu": "^2.4.3",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "^6.1.2",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-static-block": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~56.0.0",
    "happy-dom": "^20.10.6",
    "msw": "^2.14.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
