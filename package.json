{
  "name": "app-monorepo-template",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check:identity": "node scripts/check-identity.mjs",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "init": "node scripts/init-project.mjs",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "typecheck": "turbo run typecheck",
    "test:e2e": "pnpm dlx playwright test",
    "validate": "turbo run lint typecheck test build format:check && pnpm verify:tests && pnpm verify:maps && pnpm check:identity",
    "verify:expo": "cd apps/mobile && npx expo-doctor && npx expo install --check",
    "verify:maps": "node scripts/verify-maps.mjs",
    "verify:tests": "node scripts/verify-tests.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "react": "19.2.7",
      "react-dom": "19.2.7"
    },
    "packageExtensions": {
      "@tanstack/react-query": {
        "peerDependencies": {
          "@types/react": "*"
        },
        "peerDependenciesMeta": {
          "@types/react": {
            "optional": true
          }
        }
      }
    }
  }
}
