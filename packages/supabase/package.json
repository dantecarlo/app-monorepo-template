{
  "name": "@app/supabase",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.adapter.ts",
    "./ssr": "./src/ssr.adapter.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
